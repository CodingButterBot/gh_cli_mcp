{
  "mcpServers": {
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "coworker": {
      "type": "stdio",
      "command": "claude",
      "args": [
        "mcp",
        "serve"
      ]
    },
    "puppeteer": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ]
    },
    "smtp_gmail": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "mcp-smtp-gmail"
      ],
      "env": {
        "SMTP_SERVER": "smtp.gmail.com",
        "SMTP_PORT": "465",
        "IMAP_SERVER": "imap.gmail.com",
        "IMAP_PORT": "993",
        "USER_EMAIL": "autocodecalvin@gmail.com",
        "USER_PASSWORD": "lvni anry vnky drlu"
      }
    },
    "github": {
      "type": "stdio",
      "command": "gh-cli-mcp"
    }
  }
}